root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{c,h,S}]
indent_style = space
indent_size = 4
max_line_length = 80

[*.py]
indent_style = space
indent_size = 4
max_line_length = 80

[*.{rst,md}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[meson.build]
indent_style = space
indent_size = 2

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.nix]
indent_style = space
indent_size = 2
